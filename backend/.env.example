APP_NAME=LeadGen Pro API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173,https://your-vercel-project.vercel.app
GOOGLE_API_KEY=your_google_places_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_PLACES_TEXT_SEARCH_URL=https://maps.googleapis.com/maps/api/place/textsearch/json
GOOGLE_PLACES_DETAILS_URL=https://maps.googleapis.com/maps/api/place/details/json
GOOGLE_PLACES_AUTOCOMPLETE_URL=https://maps.googleapis.com/maps/api/place/autocomplete/json
LEAD_MAX_RESULTS=12
SCRAPER_MAX_CONCURRENCY=6
SCRAPER_TIMEOUT_SECONDS=5
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password
GEODB_API_KEY=your_rapidapi_key_here
GEODB_API_HOST=wft-geo-db.p.rapidapi.com
GEODB_COUNTRIES_URL=https://wft-geo-db.p.rapidapi.com/v1/geo/countries
GEODB_CITIES_URL=https://wft-geo-db.p.rapidapi.com/v1/geo/countries/{country_code}/cities
